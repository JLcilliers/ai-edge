# ── Auth ──────────────────────────────────────────────────────
# Clerk (via Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Database (Neon via Vercel Marketplace) ───────────────────
DATABASE_URL=
DIRECT_URL=

# ── Vectors (Pinecone via Vercel Marketplace) ────────────────
PINECONE_API_KEY=
PINECONE_INDEX=ai-edge

# ── Queue / cache (Upstash via Vercel Marketplace) ───────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Blob storage (Vercel Blob) ───────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── LLM access ───────────────────────────────────────────────
# Unified gateway (preferred path — ADR-0002)
AI_GATEWAY_API_KEY=

# Direct provider keys (fallback + provider-specific endpoints)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
PERPLEXITY_API_KEY=

# OpenRouter — OpenAI-compatible unified gateway covering Gemini, Llama,
# DeepSeek, Mistral, etc. with one key. Used by the audit fan-out.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_SITE_URL=https://clixsy.com
OPENROUTER_SITE_NAME=Clixsy Intercept

# ── Reddit (via RapidAPI — sparior/reddit3) ──────────────────
# Preferred path: the RapidAPI commercial tier handles auth + rate limits
# in one key. No OAuth dance, no USER_AGENT dance. See PLAN.md §5.4.
RAPIDAPI_REDDIT_KEY=
RAPIDAPI_REDDIT_HOST=reddit3.p.rapidapi.com

# Legacy PRAW path — kept for reference, not currently used.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-edge/0.1 by <reddit-username>

# ── Residential proxies (Bright Data) ────────────────────────
BRIGHT_DATA_PROXY_URL=
BRIGHT_DATA_USERNAME=
BRIGHT_DATA_PASSWORD=

# ── SERP / SEO data (DataForSEO) ─────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Google Search Console (per-client service accounts) ──────
GSC_SERVICE_ACCOUNT_KEY_PATH=

# ── Internal service URLs ────────────────────────────────────
AI_EDGE_API_URL=http://localhost:8000
AI_EDGE_WORKER_QUEUE_URL=

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development

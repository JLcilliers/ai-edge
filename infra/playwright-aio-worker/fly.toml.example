# Reference fly.toml for the Playwright AIO worker (per ADR-0010).
# Copy to fly.toml, change `app` to your unique name, then:
#   fly launch --no-deploy
#   fly secrets set WORKER_SHARED_SECRET="$(openssl rand -hex 32)"
#   fly secrets set BRIGHT_DATA_PROXY_URL="http://customer-...:pwd@brd.superproxy.io:33335"
#   fly deploy

app = "clixsy-aio-worker"            # change me
primary_region = "iad"               # match your firms' geo for least latency

[build]
  dockerfile = "Dockerfile"

[env]
  PORT = "8080"
  HEADLESS = "true"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "stop"        # cheap when idle — wakes on first request
  auto_start_machines = true
  min_machines_running = 0           # cron + manual capture only; ok to scale to 0

  [http_service.concurrency]
    type = "connections"
    hard_limit = 8                   # Playwright + Chromium is RAM-heavy; don't pile up
    soft_limit = 4

[[vm]]
  size = "shared-cpu-2x"             # bump to performance-2x for sustained scraping
  memory = "2gb"                     # Chromium needs at least 1.5gb headroom

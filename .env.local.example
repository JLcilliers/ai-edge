# ╔══════════════════════════════════════════════════════════════════════╗
# ║       Clixsy Intercept — minimum env for the Cellino Law demo        ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env.local and fill in the values below. Everything in
# the "MUST HAVE" block is required for the demo. The "NICE TO HAVE" keys
# unlock additional modules — the demo script gracefully skips modules whose
# keys aren't set, so partial configuration still produces a working demo.
#
# ────── MUST HAVE (demo will not run without these) ─────────────────────

# Neon Postgres — free tier at https://console.neon.tech (sign-up < 2 min).
# Use the "Pooled" connection string for DATABASE_URL and the unpooled one for
# DATABASE_URL_UNPOOLED (drizzle-kit migrations need a direct connection).
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require

# OpenAI — used for (a) one of the four audit fan-out providers, (b) the
# alignment-scorer LLM-as-judge, (c) the text-embedding-3-large embeddings
# in suppression. The scorer + embeddings make this NON-OPTIONAL even if
# you skip the OpenAI audit provider.
OPENAI_API_KEY=sk-proj-...

# Anthropic — second audit provider. Audits with only one provider technically
# work but consensus voting is trivial at k=1 + 1 provider. Including
# Anthropic gives the demo meaningful multi-model RAG output.
ANTHROPIC_API_KEY=sk-ant-...

# ────── NICE TO HAVE (each module degrades gracefully) ──────────────────

# OpenRouter — third audit provider (Gemini via OpenRouter). Set this if you
# want Google's model in the consensus mix without provisioning Vertex.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_SITE_URL=https://clixsy.com
OPENROUTER_SITE_NAME=Clixsy Intercept

# Perplexity Sonar — fourth audit provider with live web search.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# RapidAPI Reddit (sparior/reddit3). Unlocks Stage 4 of the demo. Without it
# the Reddit module shows "configured but quiet" — the demo skips the call.
RAPIDAPI_REDDIT_KEY=
RAPIDAPI_REDDIT_HOST=reddit3.p.rapidapi.com

# DataForSEO — primary AIO (Google AI Overview) capture provider. Without it
# Stage 5 of the demo is skipped. AIO capture costs ~$0.001–0.005 per query.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ────── NOT NEEDED FOR THE DEMO ─────────────────────────────────────────
# Clerk auth (the demo runs without Clerk wired in — dashboard is open in dev)
# Pinecone (v1 stores embeddings as jsonb on the page row)
# Bing Search / SerpAPI (only used by the SERP-capture cron — not in the demo)
# Bright Data residential proxies (only for Playwright AIO fallback)
# Vercel Blob (only used by monthly report cron — not in the demo)

# ────── Demo cost controls ──────────────────────────────────────────────
# Audit fan-out: providers × k samples × queries. With OpenAI + Anthropic at
# k=3, DEMO_QUERY_LIMIT=3 → 18 model calls + 3 alignment-scorer calls ≈ $0.50–2.
# Bump to 5 if you want a more impressive RAG mix on screen.
DEMO_QUERY_LIMIT=3
DEMO_MAX_URLS=15

# ────── Defaults — leave as-is unless you know better ───────────────────
NODE_ENV=development
DEFAULT_FIRM_MONTHLY_CAP_USD=50
